# Storefront base URL (used in absolute links / OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Medusa backend (leave blank to use mock data layer)
NEXT_PUBLIC_MEDUSA_URL=
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Bank of Georgia e-commerce gateway
BOG_CLIENT_ID=
BOG_CLIENT_SECRET=
BOG_RETURN_URL=http://localhost:3000/checkout/success
BOG_CALLBACK_URL=http://localhost:3000/api/payments/bog/callback

# TBC Bank e-commerce gateway
TBC_API_KEY=
TBC_MERCHANT_ID=
TBC_RETURN_URL=http://localhost:3000/checkout/success
TBC_CALLBACK_URL=http://localhost:3000/api/payments/tbc/callback

# Email magic-link auth
AUTH_SECRET=
EMAIL_FROM=hello@galleryregalo.ge
EMAIL_SMTP_URL=
